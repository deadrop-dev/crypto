{
  "name": "@deadrop/crypto",
  "version": "0.1.0",
  "description": "Auditable AES-256-GCM encryption library for Deadrop. Zero dependencies.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./test-vectors": {
      "import": "./test-vectors.json",
      "require": "./test-vectors.json"
    }
  },
  "files": [
    "dist",
    "test-vectors.json",
    "SPEC.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deadrop-dev/crypto.git"
  },
  "homepage": "https://deadrop.dev",
  "bugs": {
    "url": "https://github.com/deadrop-dev/crypto/issues"
  },
  "keywords": [
    "encryption",
    "aes-256-gcm",
    "zero-knowledge",
    "secret-sharing",
    "deadrop",
    "crypto",
    "web-crypto"
  ],
  "engines": {
    "node": ">=20"
  }
}
